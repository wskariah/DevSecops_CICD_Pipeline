pipeline {
    agent master

    environment {
        // General Environment Variables
        IMAGE_NAME = 'hello-world-app'
        IMAGE_TAG = 'latest'
        CONTAINER_REGISTRY = 'docker.io'

        // SonarQube Configuration
        SONARQUBE = 'SonarQube-irs'
        SONAR_TOKEN = credentials('sonarqube-token')  // SonarQube token
        SONARQUBE_URL = 'http://your-sonarqube-server-url'  // URL to your SonarQube server

        // Container Registry and Artifactory
        ARTIFACTORY_REPO = 'https:///artifactory/api/docker/wilson-docker'

        // Security Scanning
        QUALYS_API_KEY = credentials('qualys-api-key')

        // ServiceNow for Change Management
        SERVICE_NOW_TOKEN = credentials('servicenow-token')

        // URLs for Different Environments
        ECP_DEV_URL = 'https://ecp-dev.excella.com'
        ECP_PROD_URL = 'https://ecp-prod.excella.com'
        IEP_DEV_URL = 'https://iep-dev.excella.com'
        IEP_PROD_URL = 'https://iep-prod.excella.com'

        // Testing URLs and Tools
        SELENIUM_GRID_URL = 'http://selenium-grid.excella.com'
        SOAPUI_TEST_URL = 'http://soapui.excella.com'
        LOADRUNNER_URL = 'http://loadrunner.excella.com'
    }

    stages {
        stage('Build Container Image') {
            steps {
                script {
                    sh "podman build -t ${CONTAINER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Jacoco Code Coverage') {
            steps {
                script {
                    // Run tests and generate Jacoco code coverage report
                    sh '''
                        mvn clean install
                        mvn test
                    '''
                }
            }
        }

        stage('Publish Jacoco Report') {
            steps {
                script {
                    // Archive Jacoco code coverage reports to Jenkins
                    junit '**/target/test-classes/test-*.xml' // report path
                    publishHTML(target: [
                        reportName: 'Jacoco Code Coverage Report',
                        reportDir: 'target/site/jacoco',  // Jacoco output directory
                        reportFiles: 'index.html'
                    ])
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    // Run SonarQube analysis
                    sh '''
                        mvn sonar:sonar -Dsonar.projectKey=${IMAGE_NAME} -Dsonar.host.url=${SONARQUBE_URL} -Dsonar.login=${SONAR_TOKEN}
                    '''
                }
            }
        }

        stage('Qualys Static Container Security Scan') {
            steps {
                script {
                    sh "qualys-container-scan --image ${CONTAINER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} --api-key ${QUALYS_API_KEY}"
                }
            }
        }

        stage('Run Selenium Tests') {
            steps {
                script {
                    // Run Selenium tests against the application (e.g., WebDriver with Selenium Grid)
                    echo "Running Selenium tests..."
                    
                    // Example command that starts Selenium tests
                    // Assuming you have a Maven/Gradle project with Selenium tests configured
                    sh '''
                        mvn clean test -Dselenium.grid.url=${SELENIUM_GRID_URL}
                    '''
                }
            }
        }

        stage('Push Container Image to Artifactory') {
            steps {
                script {
                    sh """
                        podman login ${ARTIFACTORY_REPO} -u ${ARTIFACTORY_USERNAME} -p ${ARTIFACTORY_PASSWORD}
                        podman tag ${CONTAINER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} ${ARTIFACTORY_REPO}/${IMAGE_NAME}:${IMAGE_TAG}
                        podman push ${ARTIFACTORY_REPO}/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Pull Container Image from Artifactory') {
            steps {
                script {
                    sh "podman pull ${ARTIFACTORY_REPO}/${IMAGE_NAME}:${IMAGE_TAG}"
                }
            }
        }

        stage('Change Management Integration - ServiceNow') {
            steps {
                script {
                    sh '''
                        curl -X POST -H "Authorization: Bearer ${SERVICE_NOW_TOKEN}" -H "Content-Type: application/json" -d '{"incident": {"short_description": "Deploying to ECP Dev"}}' https://excella.service-now.com/api/now/table/incident
                    '''
                }
            }
        }

    }

    post {
        always {
            echo 'Pipeline finished!'
        }

        success {
            echo 'Pipeline successfully completed!'
        }

        failure {
            echo 'Pipeline failed!'
        }
    }
}
