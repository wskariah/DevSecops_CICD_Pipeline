apiVersion: 1.0.0
metadata:
  name: java-devspace
  version: 1.0.0
  description: "Devfile for Java Application using Maven"

components:
  # Java container with OpenJDK and Maven preinstalled
  - name: java-container
    container:
      image: maven:3.8-openjdk-11  # Image with Maven and OpenJDK 11
      memoryLimit: 2Gi
      mountSources: true  # Mount the source code directory to the container
      mountPath: /projects  # Path inside the container where the code will be mounted
      command:
        - "mvn"
        - "clean"
        - "install"
      args:
        - "-DskipTests"  # Skip tests by default during build (optional)

  # You can add additional components if needed (like a database or other services)
  - name: java-debugger
    container:
      image: maven:3.8-openjdk-11
      memoryLimit: 2Gi
      mountSources: true
      command:
        - "mvn"
        - "spring-boot:run"  # Command to run the Java application in debug mode (for Spring Boot apps)

commands:
  # This is the command to start your Java application (or debugging)
  - name: run-java-app
    actions:
      - action: run
        component: java-debugger
        args: ["spring-boot:run"]

